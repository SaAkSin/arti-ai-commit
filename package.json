{
  "name": "arti-ai-commit",
  "displayName": "arti-ai-commit",
  "description": "Git 커밋 메시지를 한국어로 자동 생성해 주는 확장 프로그램 (Gemini API 기반)",
  "version": "0.0.3",
  "publisher": "artgrammer",
  "license": "MIT",
  "icon": "images/icon.png",
  "keywords": [
    "git",
    "commit",
    "gemini",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SaAkSin/arti-ai-commit.git"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "arti-ai-commit.generateMessage",
        "title": "Generate Commit Message (Gemini)",
        "icon": "$(sparkle)"
      },
      {
        "command": "arti-ai-commit.setApiKey",
        "title": "Arti AI Commit: Set Gemini API Key"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "arti-ai-commit.generateMessage",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "publish:vscode": "vsce publish",
    "publish:openvsx": "ovsx publish",
    "publish:all": "npm run publish:vscode && npm run publish:openvsx"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.3",
    "ovsx": "^0.10.9",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@google/genai": "^1.44.0"
  }
}
